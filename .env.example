# daedalus config. Copy to .env and fill in. .env is gitignored.

# --- spend authorization ---
# attended = one human tap approves each spend (agent cannot self-approve)
# policy   = standing per-period limit, no tap under the cap
APPROVAL_MODE=attended
POLICY_SPEND_LIMIT_CENTS=1000

# --- Stripe ---
# sk_test_... to trial the whole loop (https://dashboard.stripe.com/test/apikeys)
# sk_live_... for real customers paying you real money. In live mode the agent
# collects real revenue and tracks costs, but never charges a card outbound.
STRIPE_SECRET_KEY=
# only needed if you run your own webhook endpoint; the agent polls by default.
STRIPE_WEBHOOK_SECRET=

# --- Nemotron via OpenRouter (free) ---
# from https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
# optional: route sensitive inference to a local Nemotron (Ollama/NIM, OpenAI-compatible)
LOCAL_NEMOTRON_URL=
LOCAL_NEMOTRON_MODEL=nvidia/nemotron-3-nano-30b-a3b

# --- Icarus markdown memory ---
# auto = write memories when icarus-memory is importable, otherwise label unavailable.
DAEDALUS_MEMORY_ENABLED=auto
DAEDALUS_MEMORY_ROOT=~/fabric
